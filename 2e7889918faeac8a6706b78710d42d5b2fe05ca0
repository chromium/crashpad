      "writtenOn": "2016-04-21T20:20:53Z",
      "side": 1,
      "message": "Take care with %rsp alignment on x86_64. (But if we found the stack properly-aligned for function entry and we did a jmp instead of a call, we’re probably fine.)",
      "revId": "2e7889918faeac8a6706b78710d42d5b2fe05ca0",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": false
