    {
      "key": {
        "uuid": "12329091_aa89cd90",
        "filename": "snapshot/ios/thread_snapshot_ios.cc",
        "patchSetId": 17
      },
      "lineNbr": 31,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2020-03-16T20:43:10Z",
      "side": 1,
      "message": "Since this is the same as the exception version of this function, my comments there apply here too.\n\nIf possible, we should aim for sharing. However, sharing may not be possible because you’re working with Mach context types here and POSIX signal handler context types for exceptions. They’re similar but entirely different, and not necessarily compatible because things are in different orders. Usually, the memcpy-able regions are compatible, though.",
      "revId": "3724abf967661fa6fd6feb7a8188c2f929403985",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
