    {
      "key": {
        "uuid": "9a994798_52fae8be",
        "filename": "util/file/directory_reader_test.cc",
        "patchSetId": 7
      },
      "lineNbr": 30,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-10-03T16:27:13Z",
      "side": 1,
      "message": "It wouldn’t necessarily be worthwhile if you weren’t making a temporary directory anyway, but since you are, this will be more robust if you wait until you’ve got your ScopedTempDir set up and then EXPECT_FALSE(reader.Open(temp_dir.path().Append(FILE_PATH_LITERAL(\"notadirectory\")))).",
      "revId": "9c11b4ea96413474a9f46dc6ad7aaef89e4b70a1",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
