      },
      "writtenOn": "2017-10-06T19:13:42Z",
      "side": 1,
      "message": "\u003e I’m going to migrate our existing uses of readdir_r() to just straight readdir().\n\nhttps://chromium-review.googlesource.com/705756",
      "parentUuid": "abb8a5f7_12d24be4",
      "revId": "9c11b4ea96413474a9f46dc6ad7aaef89e4b70a1",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
