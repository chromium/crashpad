      "lineNbr": 108,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2020-03-31T16:28:20Z",
      "side": 1,
      "message": "When you intersperse comments and code, always use blank lines so that it’s clear which comment applies to which code. Vertical whitespace is free.",
