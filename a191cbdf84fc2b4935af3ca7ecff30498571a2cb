      "author": {
        "id": 1116294
      },
      "writtenOn": "2020-04-02T02:46:27Z",
      "side": 1,
      "message": "How do I know the first Os version is 10.15.0?  For now I\u0027ll put 10.15 everywhere...",
      "parentUuid": "b99b29b4_e27d3647",
      "revId": "a191cbdf84fc2b4935af3ca7ecff30498571a2cb",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
