        "filename": "util/ios/exception_processor.mm",
        "patchSetId": 5
      },
      "lineNbr": 145,
      "author": {
        "id": 1116294
      },
      "writtenOn": "2020-04-02T02:46:27Z",
      "side": 1,
      "message": "how about:\n\n  static const mach_header_64* this_base_address \u003d [](){\n    Dl_info dl_info;\n    dl_info.dli_fbase \u003d nullptr;\n    if (!dladdr(reinterpret_cast\u003cconst void*\u003e(\u0026ObjcExceptionPreprocessor),\n               \u0026dl_info)) {\n      LOG(ERROR) \u003c\u003c \"dladdr: \" \u003c\u003c dlerror();\n    }\n    return reinterpret_cast\u003cconst mach_header_64*\u003e(dl_info.dli_fbase);\n  }();",
      "parentUuid": "dc9cbffc_dc84bb0a",
      "range": {
        "startLine": 139,
        "startChar": 0,
        "endLine": 145,
        "endChar": 3
      },
      "revId": "a191cbdf84fc2b4935af3ca7ecff30498571a2cb",
