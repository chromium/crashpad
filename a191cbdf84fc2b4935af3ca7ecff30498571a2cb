    {
      "key": {
        "uuid": "5d422b0b_babc208c",
        "filename": "util/ios/exception_processor.mm",
        "patchSetId": 5
      },
      "lineNbr": 114,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2020-04-02T20:52:31Z",
      "side": 1,
      "message": "\u003e OK -- but we do `__attribute__((noinline))` in chrome -- why there?\n\u003e \n\u003e Removing it here.\n\nIn Chrome, we need to force the frame to show up in the stack because that’s how we identify the uncaught NSException crashes.\n\nSince we’re moving this into Crashpad, we discussed assigning a distinct exception code. We don’t need an invented stack frame to do this. In fact, we can possibly just get the exception context we put into the dump to be the context at the point of raise. That gets all of the attribution for the crash lined up perfectly.\n\nChrome couldn’t force Crashpad to use a specific exception code (without some ridiculous plumbing), but we’re already right here in Crashpad where we decide what code we want to put into the dump, so we can do a much better job.",
      "parentUuid": "8a4ce4e3_e089f606",
      "range": {
        "startLine": 114,
        "startChar": 7,
        "endLine": 114,
        "endChar": 15
      },
      "revId": "a191cbdf84fc2b4935af3ca7ecff30498571a2cb",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": false
    },
