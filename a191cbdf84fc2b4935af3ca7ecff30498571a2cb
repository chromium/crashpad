      },
      "lineNbr": 141,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2020-03-31T16:28:20Z",
      "side": 1,
      "message": "Pointers are nullptr, not 0.",
      "range": {
        "startLine": 141,
