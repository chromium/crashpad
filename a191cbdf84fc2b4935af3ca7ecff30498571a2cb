    {
      "key": {
        "uuid": "d8e38285_f6ae93df",
        "filename": "util/ios/exception_processor.mm",
        "patchSetId": 5
      },
      "lineNbr": 221,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2020-03-31T16:28:20Z",
      "side": 1,
      "message": "This doesn’t come into play for nameless symbols, it comes into play for any symbol that didn’t match a symbol name-based sinkhole above. Given that, there isn’t really even any point to listing any of the symbols from CoreFoundation or libdispatch by symbol name.\n\nMaybe that’s not what you intended. Maybe you only wanted to do this if the symbol name came up blank?\n\nBut in general, I don’t feel very warm and fuzzy about having anything rely on unredacted names in more development-type environments, and to have an entirely different thing happen in production.",
      "range": {
        "startLine": 220,
        "startChar": 0,
        "endLine": 221,
        "endChar": 21
      },
      "revId": "a191cbdf84fc2b4935af3ca7ecff30498571a2cb",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
