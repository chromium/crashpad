    {
      "key": {
        "uuid": "311425b7_325bd67c",
        "filename": "snapshot/linux/debug_rendezvous.h",
        "patchSetId": 11
      },
      "lineNbr": 67,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-07-12T20:47:47Z",
      "side": 1,
      "message": "Be explicit (can be after the \\brief) that this excludes the executable.\n\nAlso: does this include the interpreter/loader and the kernel-supplied vdso? If so, we should probably arrange for them to be present at certain indices (either first or last). That behavior should be documented and tested too.",
      "revId": "51972c5ebce5fb5aab3a053df47440ebfeedee2e",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
