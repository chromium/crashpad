      "writtenOn": "2017-12-07T19:32:35Z",
      "side": 1,
      "message": "Should all of these file operations (WriteFileExactly too) use the logging variants?",
      "revId": "0b7cfb8859f64afc6399a3d3114454eb1450d38e",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
