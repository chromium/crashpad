    {
      "key": {
        "uuid": "b69efd5f_cb836cfa",
        "filename": "util/linux/elf_dynamic_table_reader.cc",
        "patchSetId": 19
      },
      "lineNbr": 37,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-06-23T21:42:24Z",
      "side": 1,
      "message": "There’s no sense in reading a partial DynType either, if size is not a proper multiple of sizeof(DynType). As it is, you’d populate part of a DynType and then treat the whole thing as valid, even the bytes that you didn’t read.\n\nYou could check size \u003e\u003d sizeof(buffer) instead of size \u003e 0.",
      "revId": "ee519d37bcefddd4852adf8bf9f0cde9c1a4b551",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
