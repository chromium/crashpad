      },
      "lineNbr": 44,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-06-23T21:42:24Z",
      "side": 1,
      "message": "buffer is [1], having this loop just complicates things.\n\nIf you’re going to have buffer[1], you might as well have it not be an array, and use \u0026buffer in place of buffer.",
      "revId": "ee519d37bcefddd4852adf8bf9f0cde9c1a4b551",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
