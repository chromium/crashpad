    {
      "key": {
        "uuid": "62e7eea3_8f43d776",
        "filename": "util/linux/elf_image_reader.cc",
        "patchSetId": 19
      },
      "lineNbr": 67,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-06-23T21:42:24Z",
      "side": 1,
      "message": "This is kind of more of an Initialize() in local parlance, right?\n\nIn fact, you can throw an INITIALIZATION_STATE_DCHECK on here and test it in GetProgramHeader() and GetLoadBias()/GetPreferredBaseAddress().\n\nAs Initialize(), it’d also make more sense to move it above the getters, so that a top-down read of this class is more sensible.",
      "revId": "ee519d37bcefddd4852adf8bf9f0cde9c1a4b551",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
