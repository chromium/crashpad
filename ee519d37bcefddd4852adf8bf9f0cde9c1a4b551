        "id": 1174099
      },
      "writtenOn": "2017-06-23T21:42:24Z",
      "side": 1,
      "message": "Give this a protected destructor or a public virtual destructor to make sure that this is used correctly.",
      "revId": "ee519d37bcefddd4852adf8bf9f0cde9c1a4b551",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
