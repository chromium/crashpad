      "writtenOn": "2017-08-01T21:27:29Z",
      "side": 1,
      "message": "If the signal handler never ran, nothing in this test will fail. We should fail the test in that case. You could have the handler set a bool.",
      "revId": "5efd913a4e66d49218b182a25d931027e19dec97",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
