    {
      "key": {
        "uuid": "ab66a1bd_399b3f9b",
        "filename": "util/linux/ptrace_requests.cc",
        "patchSetId": 20
      },
      "lineNbr": 218,
      "author": {
        "id": 1172779
      },
      "writtenOn": "2017-05-16T17:11:03Z",
      "side": 1,
      "message": "I\u0027m not totally sure what happens when an ARM cpu doesn\u0027t have the fpa register set.\nI checked back to Linux 3.0 and didn\u0027t see anything indicating that this register set was only conditionally present in the thread_info struct.\nI\u0027m guessing that the kernel would copy zeros/garbage if the registers didn\u0027t exist on the cpu and a failure here would be more likely due to something other than the registers not being present.\n\nI haven\u0027t yet been able to get Android Studio to create a virtual device without a floating point unit to test this.",
      "parentUuid": "37925ec7_03c9ea96",
      "revId": "86ccb582c47070c865ada7ba998609af66e43cae",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
