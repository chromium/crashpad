    {
      "key": {
        "uuid": "47857816_2d654743",
        "filename": "util/linux/ptrace_requests.cc",
        "patchSetId": 20
      },
      "lineNbr": 90,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-05-15T18:40:15Z",
      "side": 1,
      "message": "Since we have our own structure now, this is just sizeof(FloatContext::f32::vfp), right? I think we can get rid of this.",
      "revId": "86ccb582c47070c865ada7ba998609af66e43cae",
