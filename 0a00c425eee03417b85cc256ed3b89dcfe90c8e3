      "author": {
        "id": 1177549
      },
      "writtenOn": "2017-03-24T17:26:38Z",
      "side": 1,
      "message": "Logging both for belt-and-suspenders. err might be significant if ever it\u0027s not WAIT_FAILED.",
      "parentUuid": "e902ead3_3cb090d5",
      "revId": "0a00c425eee03417b85cc256ed3b89dcfe90c8e3",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
