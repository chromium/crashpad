    {
      "key": {
        "uuid": "3a4d4b36_364c7aec",
        "filename": "snapshot/linux/signal_context.h",
        "patchSetId": 2
      },
      "lineNbr": 317,
      "author": {
        "id": 1256356
      },
      "writtenOn": "2018-05-28T18:17:40Z",
      "side": 1,
      "message": "I\u0027ve done rework of context structures for mips, merging them where possible into single type for 32bit and 64bit architectures, as registers in contexts are always (except for NT_PRSTATUS) treated as 64bit wide for both (for mips).\n\nThis presents problem for MIPS in Ptracer::Is64Bit(), as it tests context structure size to figure out bitness, which is impossible for us as context is same size for 32bit and 64bit. I\u0027ve circumvented this by a hack, as I couldn\u0027t think of a nicer solution. (this is perhaps more clear in comment in util/linux/thread_info.h around line 115).",
      "parentUuid": "ca035dbb_0309603f",
      "range": {
        "startLine": 309,
        "startChar": 0,
        "endLine": 317,
        "endChar": 2
      },
      "revId": "c1e5319dc61ae05305e2418b62271438079c23b5",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
