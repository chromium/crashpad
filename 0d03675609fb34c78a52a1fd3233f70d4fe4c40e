      },
      "lineNbr": 66,
      "author": {
        "id": 1172779
      },
      "writtenOn": "2019-07-18T00:52:46Z",
      "side": 1,
      "message": "I don\u0027t think we need to duplicate this logic here in Crashpad. Passing this flag around to the right process types is already handled by Chrome.",
      "range": {
        "startLine": 57,
        "startChar": 0,
        "endLine": 66,
        "endChar": 1
      },
      "revId": "0d03675609fb34c78a52a1fd3233f70d4fe4c40e",
