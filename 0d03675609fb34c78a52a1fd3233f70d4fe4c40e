        "id": 1298800
      },
      "writtenOn": "2019-07-17T20:22:47Z",
      "side": 1,
      "message": "Is this right? Do we want to always redirect here and not to the user\u0027s home dir for logging?",
      "range": {
        "startLine": 513,
        "startChar": 0,
        "endLine": 513,
        "endChar": 66
      },
      "revId": "0d03675609fb34c78a52a1fd3233f70d4fe4c40e",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
