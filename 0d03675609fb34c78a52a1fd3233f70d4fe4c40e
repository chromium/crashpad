    {
      "key": {
        "uuid": "04f25133_4efd66f7",
        "filename": "handler/linux/crash_report_exception_handler.cc",
        "patchSetId": 1
      },
      "lineNbr": 286,
      "author": {
        "id": 1172779
      },
      "writtenOn": "2019-07-18T00:52:46Z",
      "side": 1,
      "message": "This should be chrome\u0027s euid, which might not always be the same as Crashpad\u0027s. We can pass this information in from the client\u0027s dump request:\nhttps://osscs.corp.google.com/chromium/chromium/src/+/master:third_party/crashpad/crashpad/handler/linux/exception_handler_server.cc;l\u003d444\n\nOr Crashpad can collect it with a ProcessInfo:\nhttps://osscs.corp.google.com/chromium/chromium/src/+/master:third_party/crashpad/crashpad/util/posix/process_info.h;l\u003d104",
      "range": {
        "startLine": 286,
        "startChar": 45,
        "endLine": 286,
        "endChar": 52
      },
      "revId": "0d03675609fb34c78a52a1fd3233f70d4fe4c40e",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
