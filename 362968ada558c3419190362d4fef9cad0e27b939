    {
      "key": {
        "uuid": "6d6ad0de_615032c8",
        "filename": "snapshot/ios/exception_snapshot_ios.cc",
        "patchSetId": 10
      },
      "lineNbr": 156,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2020-04-24T15:20:22Z",
      "side": 1,
      "message": "But this isn’t the type you have!\n\nYou asked for MACHINE_THREAD_STATE. As we discussed yesterday, that’s arm_unified_thread_state_t, not arm_thread_state64_t.",
      "range": {
        "startLine": 155,
        "startChar": 0,
        "endLine": 156,
        "endChar": 59
      },
      "revId": "362968ada558c3419190362d4fef9cad0e27b939",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
