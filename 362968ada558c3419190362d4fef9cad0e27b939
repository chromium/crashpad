      "lineNbr": 149,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2020-04-24T15:20:22Z",
      "side": 1,
      "message": "(here is where you’d use a thread_get_state x86_THREAD_STATE64 as a backstop against being invoked with a bad or unusable flavor…better than nothing.)",
      "revId": "362968ada558c3419190362d4fef9cad0e27b939",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
