      "side": 1,
      "message": "\u003e I use reset for things like (see usage of |current| in this method.)\n\u003e \n\u003e // static\n\u003e void InProcessIntermediatedumpHandler::WriteAnnotationList(\n\u003e     IOSIntermediatedumpWriter* writer,\n\u003e     process_types::CrashpadInfo* crashpad_info) {\n\u003e   if (!crashpad_info-\u003eannotations_list) {\n\u003e     return;\n\u003e   }\n\u003e   ScopedVMRead\u003cprocess_types::AnnotationList\u003e annotation_list(\n\u003e       crashpad_info-\u003eannotations_list);\n\u003e   if (!annotation_list.is_valid()) {\n\u003e     LOG(WARNING) \u003c\u003c \"could not read annotations list object\";\n\u003e     return;\n\u003e   }\n\u003e   IOSIntermediatedumpWriter::ScopedArray annotationsArray(\n\u003e       writer, IntermediateDumpKey::kAnnotationObjects);\n\u003e   ScopedVMRead\u003cprocess_types::Annotation\u003e current(\u0026annotation_list-\u003ehead);\n\u003e   if (!current.is_valid()) {\n\u003e     LOG(WARNING) \u003c\u003c \"could not read annotation\";\n\u003e     return;\n\u003e   }\n\u003e   for (size_t index \u003d 0;\n\u003e        current-\u003elink_node !\u003d annotation_list.get()-\u003etail_pointer \u0026\u0026\n\u003e        index \u003c kMaxNumberOfAnnotations;\n\u003e        ++index) {\n\u003e     ScopedVMRead\u003cprocess_types::Annotation\u003e node(current-\u003elink_node);\n\u003e     if (!node.is_valid()) {\n\u003e       LOG(WARNING) \u003c\u003c \"could not read annotation\";\n\u003e       return;\n\u003e     }\n\u003e     current.reset(\n\u003e         reinterpret_cast\u003cprocess_types::Annotation*\u003e(current-\u003elink_node));\n\nOne thing that I’m noticing here is that you don’t check current.is_valid().\n\nYou’d always want to check validity any time you ask ScopedVMRead to read something new. That’s really an argument for there to be a single method that returns a success boolean. (We don’t really use WARN_UNUSED_RESULT in Crashpad, but we do expect that success will be checked meticulously.)\n\nThis is an argument in favor of providing _only_ that interface. You wouldn’t need is_valid in that case, and you wouldn’t want the constructors at all, because they can’t report status.\n\nThis discussion only concerns the outer, user-facing ScopedVMRead. The internal class can do whatever, since it’s intended only to be used by the outer class, and can trust the outer class to use it correctly. Although if it’s easier to do so, the inner class’ interface can be adapted to match the outer too.\n\n\u003e     if (node-\u003esize \u003d\u003d 0)\n\u003e       continue;\n\u003e     if (node-\u003esize \u003e Annotation::kValueMaxSize) {\n\u003e       DLOG(WARNING) \u003c\u003c \"Incorrect annotation length \" \u003c\u003c node-\u003esize;\n\u003e       continue;\n\u003e     }\n\u003e     IOSIntermediatedumpWriter::ScopedMap annotationMap(writer);\n\u003e     const size_t name_len \u003d\n\u003e         strnlen((const char*)node-\u003ename, Annotation::kNameMaxLength);\n\u003e     writer-\u003eAddProperty(IntermediateDumpKey::kAnnotationName,\n\u003e                         reinterpret_cast\u003cconst void*\u003e(node-\u003ename),\n\u003e                         name_len);\n\u003e     writer-\u003eAddProperty(IntermediateDumpKey::kAnnotationValue,\n\u003e                         reinterpret_cast\u003cconst void*\u003e(node-\u003evalue),\n\u003e                         node-\u003esize);\n\u003e     writer-\u003eAddProperty(IntermediateDumpKey::kAnnotationType,\n\u003e                         reinterpret_cast\u003cconst void*\u003e(\u0026node-\u003etype),\n\u003e                         sizeof(node-\u003etype));\n\u003e   }\n\u003e }",
