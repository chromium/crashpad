    {
      "key": {
        "uuid": "ae0eb620_a76a6118",
        "filename": "util/win/process_info.cc",
        "patchSetId": 1
      },
      "lineNbr": 43,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-02-07T21:30:38Z",
      "side": 1,
      "message": "\u003e I envision we\u0027ll want to use this for other troublesome allocation spots, in which case you\u0027ll have to duplicate the reset()-before-alloc pattern everywhere. Your call, but the interface factors this out , as-is.\n\nI just think that people are accustomed to calling malloc-style allocators as a(size), and this stashes away some extra magic. I’ll acquiesce if you really like it. Scott can cast the tie-breaking vote.",
      "parentUuid": "f480c316_839e04f6",
      "revId": "7f90922bda75a748794096fb4205c84e37525faf",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
