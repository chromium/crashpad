        "id": 1174099
      },
      "writtenOn": "2017-02-07T19:31:08Z",
      "side": 1,
      "message": "Why doesn’t this return a UniqueMallocPtr instead? I think that’d be a more natural interface.",
      "revId": "7f90922bda75a748794096fb4205c84e37525faf",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
