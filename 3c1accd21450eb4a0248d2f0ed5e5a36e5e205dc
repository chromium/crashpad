    {
      "key": {
        "uuid": "289fda6b_93197827",
        "filename": "client/crashpad_client_win_test.cc",
        "patchSetId": 1
      },
      "lineNbr": 89,
      "author": {
        "id": 1177549
      },
      "writtenOn": "2017-03-24T15:25:39Z",
      "side": 1,
      "message": "Sorry, I rewrote this code several times - initially I thought this code could run in the child process, rejigging...",
      "parentUuid": "3c815bcf_002e50b0",
      "revId": "3c1accd21450eb4a0248d2f0ed5e5a36e5e205dc",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
