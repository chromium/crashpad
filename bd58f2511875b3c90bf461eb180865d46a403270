      "writtenOn": "2017-12-21T20:25:58Z",
      "side": 1,
      "message": "Do we want NODEFER? (Not saying yes or no, just asking.)",
      "range": {
        "startLine": 62,
        "startChar": 19,
        "endLine": 62,
        "endChar": 29
      },
      "revId": "bd58f2511875b3c90bf461eb180865d46a403270",
