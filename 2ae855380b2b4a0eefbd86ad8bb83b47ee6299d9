        "id": 1174099
      },
      "writtenOn": "2017-03-08T16:47:07Z",
      "side": 1,
      "message": "(!status_file.get()) is fine. Appears a few other times in this file too.",
      "revId": "2ae855380b2b4a0eefbd86ad8bb83b47ee6299d9",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
