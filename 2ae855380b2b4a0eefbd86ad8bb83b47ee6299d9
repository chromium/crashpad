      "lineNbr": 328,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-03-08T16:47:07Z",
      "side": 1,
      "message": "Similar comments apply to this function too.",
      "revId": "2ae855380b2b4a0eefbd86ad8bb83b47ee6299d9",
