# The value in this file must match the following schema from the `schema`
# library:
#
#   Schema([{
#     'builders': [str],
#     'step_name: str,
#     'isolate': str,
#     'args': [str],
#   }])
#
# If the builder running the tests is listed in `builders`, then
# the isolate listed in `isolated` (given as a src-absolute path) will
# be *synchronously* run under swarming, using the given `step_name` to
# identify it, and with the given `args` passed as-is to swarming.py.

[
  {
    'builders': [
      'crashpad_try_win_x86_wow64_rel',
      'crashpad_win_x86_wow64_rel',
    ],
    'step_name': 'run_tests on x86',
    'isolate': '//out/Release/run_tests.isolate',
    'args': [
      '--dimension', 'os', 'Windows-7',
      '--dimension', 'cpu', 'x86-32',
      '--dimension', 'pool', 'Chrome',
      '--hard-timeout', '300', # 5 minutes
    ],
  },
  {
    'builders': [
      'crashpad_try_win_x86_wow64_dbg',
      'crashpad_win_x86_wow64_dbg',
    ],
    'step_name': 'run_tests on x86',
    'isolate': '//out/Debug/run_tests.isolate',
    'args': [
      '--dimension', 'os', 'Windows-7',
      '--dimension', 'cpu', 'x86-32',
      '--dimension', 'pool', 'Chrome',
      '--hard-timeout', '300', # 5 minutes
    ],
  },
]
