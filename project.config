[project]
	description = A crash-reporting system
[access]
	inheritFrom = crashpad
[submit]
	action = cherry pick

[label "Commit-Queue"]
	abbreviation = CQ
	value =  0 Not ready
	value = +1 Dry run
	value = +2 Commit
	defaultValue = 0
	function = NoBlock

[access "refs/for/refs/*"]
	addPatchSet = group chrome-commit-bot
[access "refs/heads/*"]
	label-Commit-Queue = 0..+2 group Registered Users
	labelAs-Commit-Queue = group Registered Users
	labelAs-Commit-Queue = 0..+2 group chrome-commit-bot
	submit = group chrome-commit-bot
[access "refs/for/refs/heads/doc"]
	push = group crashpad-owners
	pushMerge = group crashpad-owners

[notify "crashpad-dev"]
	email = crashpad-dev@chromium.org
	type = all_comments
	type = submitted_changes
	header = cc
