      "writtenOn": "2018-04-24T15:06:56Z",
      "side": 1,
      "message": "crlf1 is never touched directly. Are we relying below on buf.data[data_bytes] overflowing the write into it?",
      "range": {
        "startLine": 230,
        "startChar": 35,
