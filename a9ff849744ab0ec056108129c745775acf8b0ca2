      "lineNbr": 230,
      "author": {
        "id": 1144260
      },
      "writtenOn": "2018-04-24T16:39:42Z",
      "side": 1,
      "message": "Right, if a full buf.data was read (i.e. data_bytes is exactly 32k), then the addition of the \\r\\n termination overflows into crlf1, otherwise, it\u0027s at the end of the data, after the actual data.",
      "parentUuid": "ec6d381b_764678cd",
      "range": {
        "startLine": 230,
        "startChar": 35,
        "endLine": 230,
        "endChar": 63
      },
      "revId": "a9ff849744ab0ec056108129c745775acf8b0ca2",
