        "id": 1144624
      },
      "writtenOn": "2017-10-20T22:45:38Z",
      "side": 1,
      "message": "I think |\u003d default| for these is now the preferred style? (It is in Chromium, at least).",
      "range": {
        "startLine": 142,
        "startChar": 44,
        "endLine": 142,
        "endChar": 65
      },
      "revId": "4912029b6e8635cef5231165b46d8a63e4b4e971",
