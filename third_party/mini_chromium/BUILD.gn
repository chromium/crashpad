import("../../build/crashpad_buildconfig.gni")

if (crashpad_is_in_chromium) {
  group("base") {
    public_deps = [
      "//base",
    ]
  }
} else {
  config("base_config") {
    if (crashpad_is_in_fuchsia) {
      include_dirs = [ "." ]
    } else if (crashpad_is_standalone) {
      include_dirs = [ "mini_chromium" ]
    }
  }

  static_library("base") {
    if (crashpad_is_in_fuchsia) {
      import("//third_party/mini_chromium/base/base_files.gni")
      configs += [ ":base_config" ]
    } else if (crashpad_is_standalone) {
      import("//third_party/mini_chromium/mini_chromium/base/base_files.gni")
    }
    public_configs = [ ":base_config" ]
    sources = base_sources
    libs = base_libs
  }
}

group("base_test_support") {
  if (crashpad_is_in_chromium) {
    public_deps = [
      "//base:test_support",
    ]
  }
}
