      "writtenOn": "2017-06-30T21:06:19Z",
      "side": 1,
      "message": "Say that it’s in the process’ address space. That’ll clarify that it’s not just the raw value stored in the ELF file.",
      "revId": "ba3472105c0496ec7447e72c8ea1318c1dfe8674",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
