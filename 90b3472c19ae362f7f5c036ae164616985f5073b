      "writtenOn": "2017-12-06T22:07:29Z",
      "side": 1,
      "message": "sdk_version should be optional.\n\nOr if it’s hard to call in that way from gn, we should have some value for it that we treat as meaning “default”.",
      "range": {
        "startLine": 22,
        "startChar": 34,
