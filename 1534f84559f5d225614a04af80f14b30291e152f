    {
      "key": {
        "uuid": "a321451f_830d6036",
        "filename": "util/stream/base94_output_stream.cc",
        "patchSetId": 2
      },
      "lineNbr": 69,
      "author": {
        "id": 1000825
      },
      "writtenOn": "2019-10-21T23:37:24Z",
      "side": 1,
      "message": "The flush_needed_ is reset after flush, it has the same effect of initialized_.set_invalid(), currently, FinishEncoding/Decoding() won\u0027t be called again, just another call to output_stream_-\u003eFlush().\n\nSince we allowed to call Flush() without Write(), maybe add another boolean data memeber and have DCHECK() here? or it is over-skill?",
      "parentUuid": "e3482fc7_bae99594",
      "range": {
        "startLine": 69,
        "startChar": 25,
        "endLine": 69,
        "endChar": 30
      },
      "revId": "1534f84559f5d225614a04af80f14b30291e152f",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
