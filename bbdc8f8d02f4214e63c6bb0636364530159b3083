      "writtenOn": "2020-04-02T21:59:02Z",
      "side": 1,
      "message": "Not ::, just a space.\n\nWe’d use :: to talk about, say, a field in a struct.\n\nSame on lines 144 and 229.",
      "range": {
        "startLine": 137,
        "startChar": 55,
        "endLine": 137,
        "endChar": 57
      },
      "revId": "bbdc8f8d02f4214e63c6bb0636364530159b3083",
