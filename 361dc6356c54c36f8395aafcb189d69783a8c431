    {
      "key": {
        "uuid": "c5f1bf4a_2b9a477b",
        "filename": "client/crashpad_client_linux.cc",
        "patchSetId": 7
      },
      "lineNbr": 438,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2020-06-08T16:10:50Z",
      "side": 1,
      "message": "Fewer system calls if you map the whole thing as PROT_NONE and then set the middle usable region to PROT_READ | PROT_WRITE after.",
      "revId": "361dc6356c54c36f8395aafcb189d69783a8c431",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
