      "writtenOn": "2020-07-15T03:10:25Z",
      "side": 1,
      "message": "1. Done.\n\n2. Also, done. This would be needed for the component build, at least, and should be okay generally.",
      "parentUuid": "8ac689ce_fa1d3711",
      "revId": "361dc6356c54c36f8395aafcb189d69783a8c431",
