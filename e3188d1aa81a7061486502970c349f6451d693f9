    {
      "key": {
        "uuid": "42ba3721_3aace0af",
        "filename": "util/win/registration_protocol_win.cc",
        "patchSetId": 6
      },
      "lineNbr": 263,
      "author": {
        "id": 1149139
      },
      "writtenOn": "2019-12-09T20:11:30Z",
      "side": 1,
      "message": "A good question, to ask the original author of the old code no doubt, I just maintained the same external interface but I don\u0027t care if we want to change it.\n\nThat said PSECURITY_DESCRIPTOR is just void* where as SECURITY_DESCRIPTOR* is a pointer to a absolute security descriptor structure which isn\u0027t even the correct type as both the fallback and (as documented) BuildSecurityDescriptor return a relative security descriptor which is SECURITY_DESCRIPTOR_RELATIVE. I\u0027d be happen to change it to PSECURITY_DESCRIPTOR and also remove the const\u0027ness (as all we do is cast it away immediately anyway) but that just provides a descriptive type rather than anything meaningful to the type system.",
      "parentUuid": "7aab8bd9_970b9bb6",
      "revId": "e3188d1aa81a7061486502970c349f6451d693f9",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
