        "id": 1172779
      },
      "writtenOn": "2019-04-29T16:41:32Z",
      "side": 1,
      "message": "I stuck with DLOG for now, which seems especially handy to have during integration.",
      "parentUuid": "bff71038_7b68ba53",
      "range": {
        "startLine": 41,
        "startChar": 4,
        "endLine": 41,
        "endChar": 11
      },
