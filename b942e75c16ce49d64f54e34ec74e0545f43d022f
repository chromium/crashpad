    {
      "key": {
        "uuid": "94130735_bb2537c3",
        "filename": "handler/linux/exception_handler_server_test.cc",
        "patchSetId": 14
      },
      "lineNbr": 366,
      "author": {
        "id": 1172779
      },
      "writtenOn": "2019-04-24T19:41:03Z",
      "side": 1,
      "message": "Yep, I expect that\u0027s what will happen.\ncrbug.com/crashpad/265 is about lss for all the various signal handler system calls, which I was planning on including this on. I\u0027ll stick that link here too.\n\nI\u0027m planning on getting this bit done in parallel with the in-chromium development.",
      "parentUuid": "89d31448_275a137f",
      "range": {
        "startLine": 365,
        "startChar": 49,
        "endLine": 366,
        "endChar": 48
      },
      "revId": "b942e75c16ce49d64f54e34ec74e0545f43d022f",
