{
    "facets": {
        "fuchsia.test": {
            "system-services": [
                "fuchsia.posix.socket.Provider",
                "fuchsia.net.NameLookup"
            ]
        }
    },
    "program": {
        "binary": "test/crashpad_tests"
    },
    "sandbox": {
        "features": [
            "system-temp",
            "deprecated-ambient-replace-as-executable"
        ],
        "services": [
            "fuchsia.posix.socket.Provider",
            "fuchsia.net.NameLookup",
            "fuchsia.process.Launcher"
        ]
    }
}
