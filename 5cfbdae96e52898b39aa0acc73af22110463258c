        "id": 1172779
      },
      "writtenOn": "2018-05-04T02:04:02Z",
      "side": 1,
      "message": "The mac, linux, and win versions handle process suspension in CrashReportExceptionHandler. You\u0027re doing it here for this zx_task_resume()?",
      "range": {
        "startLine": 81,
        "startChar": 8,
        "endLine": 81,
        "endChar": 22
      },
      "revId": "5cfbdae96e52898b39aa0acc73af22110463258c",
