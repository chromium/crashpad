    },
    {
      "key": {
        "uuid": "3caa63c4_5448c065",
        "filename": "handler/handler_main.cc",
        "patchSetId": 9
      },
      "lineNbr": 401,
      "author": {
        "id": 1172779
      },
      "writtenOn": "2018-05-04T02:04:02Z",
      "side": 1,
      "message": "This is intended to install a crash handler for this process, not the target. I think as things are, crashpad_handler crashes will still get caught by the exception port set up by StartHandler since the handler is part of the same job as the client, but then those exceptions will be handled by ExceptionHandlerServer which might be in a bad state. This would be a corollary to crashlogger\u0027s self_dump_port.",
      "range": {
        "startLine": 399,
        "startChar": 0,
        "endLine": 401,
        "endChar": 43
      },
