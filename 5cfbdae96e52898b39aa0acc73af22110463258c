      "unresolved": true
    },
    {
      "key": {
        "uuid": "b41501e8_bb629140",
        "filename": "handler/fuchsia/exception_handler_server.h",
        "patchSetId": 9
      },
      "lineNbr": 38,
      "author": {
        "id": 1172779
      },
      "writtenOn": "2018-05-04T02:04:02Z",
      "side": 1,
      "message": "Using ScopedZxHandles instead can help clarify ownership and minimizes the time that these handles are unmanaged. We also do similarly with mac and linux\u0027s ExceptionHandlerServers.",
      "range": {
        "startLine": 38,
        "startChar": 25,
        "endLine": 38,
        "endChar": 73
      },
      "revId": "5cfbdae96e52898b39aa0acc73af22110463258c",
