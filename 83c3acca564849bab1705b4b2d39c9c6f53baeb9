    {
      "key": {
        "uuid": "e8cdd882_f0caa581",
        "filename": "snapshot/elf/elf_image_reader.cc",
        "patchSetId": 10
      },
      "lineNbr": 249,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-12-01T03:22:28Z",
      "side": 1,
      "message": "or 8-byte for ELF64?",
      "range": {
        "startLine": 249,
        "startChar": 26,
        "endLine": 249,
        "endChar": 32
      },
      "revId": "83c3acca564849bab1705b4b2d39c9c6f53baeb9",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
