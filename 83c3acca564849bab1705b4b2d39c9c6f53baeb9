        "id": 1172779
      },
      "writtenOn": "2017-12-01T21:31:24Z",
      "side": 1,
      "message": "Outlook doesn\u0027t look good.\nThe test binary I have says the note segment has p_align \u003d 4, but has p_vaddr \u003d 0x24e.",
      "parentUuid": "b0ea6ba6_6ec1f1d7",
      "revId": "83c3acca564849bab1705b4b2d39c9c6f53baeb9",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
