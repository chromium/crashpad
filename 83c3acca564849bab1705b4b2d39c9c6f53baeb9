        "id": 1174099
      },
      "writtenOn": "2017-12-01T03:22:28Z",
      "side": 1,
      "message": "This is current_address_, it just happens to be inside a segment, right?",
      "revId": "83c3acca564849bab1705b4b2d39c9c6f53baeb9",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
