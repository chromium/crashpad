    {
      "key": {
        "uuid": "041835d6_6580650b",
        "filename": "handler/fuchsia/crash_report_exception_handler.cc",
        "patchSetId": 3
      },
      "lineNbr": 33,
      "author": {
        "id": 1001385
      },
      "writtenOn": "2018-07-27T12:19:16Z",
      "side": 1,
      "message": "I think (judging by the scoped_task_suspend include above) that the idea was originally to use ScopedTaskSuspend, which works on both Processes and Threads (and notionally the OS layer API should really work on Processes, Threads and Jobs, since those are all Tasks).\n\nHowever, this code is handling an exception on an individual thread, so (1) it\u0027s not a token-based suspend that ScopedTaskSuspend can resume us from and (2) we only need to resume an individual thread.\n\nI\u0027ve therefore renamed it to *Thread*. I\u0027ve also removed the errant include and made this a class, since that seems a more in-keeping with style guide.",
      "parentUuid": "c02359c7_0d8c793e",
      "range": {
        "startLine": 33,
        "startChar": 10,
        "endLine": 33,
        "endChar": 14
      },
      "revId": "086ebd34af6e1eaf391202ffb2b600ce84ca57cf",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": false
    },
