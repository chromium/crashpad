    {
      "key": {
        "uuid": "c02359c7_0d8c793e",
        "filename": "handler/fuchsia/crash_report_exception_handler.cc",
        "patchSetId": 3
      },
      "lineNbr": 33,
      "author": {
        "id": 1174099
