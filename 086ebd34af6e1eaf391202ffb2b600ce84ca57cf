    {
      "key": {
        "uuid": "dcc0a584_dd6cb397",
        "filename": "util/fuchsia/koid_utilities.h",
        "patchSetId": 3
      },
      "lineNbr": 42,
      "author": {
        "id": 1001385
      },
      "writtenOn": "2018-07-24T21:17:37Z",
      "side": 1,
      "message": "libzx\u0027 hierarchy is a little quirky; zx::handle is a distinct and incompatible container type from e.g. zx::process, and zx::object\u003c\u003e is a template used to instantiate all the other container types - zx::object_base is actually the single common base of them all.",
      "range": {
        "startLine": 42,
        "startChar": 43,
        "endLine": 42,
        "endChar": 59
      },
      "revId": "086ebd34af6e1eaf391202ffb2b600ce84ca57cf",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
