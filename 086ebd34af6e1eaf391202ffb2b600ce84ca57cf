    {
      "key": {
        "uuid": "e9a9010b_43febf82",
        "filename": "util/fuchsia/koid_utilities.cc",
        "patchSetId": 3
      },
      "lineNbr": 137,
      "author": {
        "id": 1001385
      },
      "writtenOn": "2018-07-27T12:19:16Z",
      "side": 1,
      "message": "Yes, we can (usually) query the type of a handle. I\u0027ve made GetChildHandleFromKoid() a template, so that it can check that the handle type matches the TYPE of the return-value container type.",
      "parentUuid": "d08f5363_a10015b8",
      "range": {
        "startLine": 137,
        "startChar": 9,
        "endLine": 137,
        "endChar": 19
      },
      "revId": "086ebd34af6e1eaf391202ffb2b600ce84ca57cf",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": false
