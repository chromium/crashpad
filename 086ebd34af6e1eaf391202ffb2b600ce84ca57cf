        "id": 1174099
      },
      "writtenOn": "2018-07-26T14:33:09Z",
      "side": 1,
      "message": "\u003e Note that forcibly wrapping the result into a zx::thread is safe because |parent| is a zx::process, so can only have thread children.\n\nIs there a run-time DCHECK you can make for that?",
      "parentUuid": "e35b4f8c_efb531d3",
      "range": {
        "startLine": 137,
        "startChar": 9,
        "endLine": 137,
        "endChar": 19
