    {
      "key": {
        "uuid": "82893c04_33cd8cea",
        "filename": "util/fuchsia/koid_utilities.cc",
        "patchSetId": 3
      },
      "lineNbr": 62,
      "author": {
        "id": 1001385
      },
      "writtenOn": "2018-07-24T21:17:37Z",
      "side": 1,
      "message": "Previously this and the loop below used GetChildHandles(), which fetched the list of koids and then looked-up each one to get to a handle, which this loop then iterated over.  This version instead iterates over the koids, only opening the one that matches.\n\nIf we don\u0027t find the koid and instead have to look in nested jobs then we\u0027re only holding each job open while we search inside it, i.e. the maximum # of open handles is ~depth of traversal.\n\nThis does have the disadvantage that since we are not taking handles to all the children until we reach them in the iteration, they may have exited before we reach them, and therefore be gone, but since we are looking up a particular child process, I think we should be able to assume that it is stopped, waiting for us to handle the exception on it?",
      "range": {
        "startLine": 62,
        "startChar": 7,
        "endLine": 62,
        "endChar": 66
      },
      "revId": "086ebd34af6e1eaf391202ffb2b600ce84ca57cf",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "0a33c9c9_aaa20b54",
        "filename": "util/fuchsia/koid_utilities.cc",
        "patchSetId": 3
      },
      "lineNbr": 62,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2018-07-26T14:33:09Z",
      "side": 1,
      "message": "\u003e Previously this and the loop below used GetChildHandles(), which fetched the list of koids and then looked-up each one to get to a handle, which this loop then iterated over.  This version instead iterates over the koids, only opening the one that matches.\n\u003e \n\u003e If we don\u0027t find the koid and instead have to look in nested jobs then we\u0027re only holding each job open while we search inside it, i.e. the maximum # of open handles is ~depth of traversal.\n\nSo the comment below should be revised.\n\n\u003e This does have the disadvantage that since we are not taking handles to all the children until we reach them in the iteration, they may have exited before we reach them, and therefore be gone, but since we are looking up a particular child process, I think we should be able to assume that it is stopped, waiting for us to handle the exception on it?\n\nIt’s possible that some outsider with appropriate access requested a dump of a non-crashing victim process.\n\nStill, it might not really be worth worrying about.",
      "parentUuid": "82893c04_33cd8cea",
      "range": {
        "startLine": 62,
        "startChar": 7,
        "endLine": 62,
        "endChar": 66
      },
      "revId": "086ebd34af6e1eaf391202ffb2b600ce84ca57cf",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "d6c6b44a_2d47e3b8",
        "filename": "util/fuchsia/koid_utilities.cc",
