      "unresolved": true
    },
    {
      "key": {
        "uuid": "616b8db0_6c43649d",
        "filename": "client/crash_report_database_win.cc",
        "patchSetId": 4
      },
      "lineNbr": 1063,
      "author": {
        "id": 1429565
      },
      "writtenOn": "2020-06-23T21:03:19Z",
      "side": 1,
      "message": "Changed function UUIDFromReportPath: added UUID* as an argument, and the function returns true on success (if uuid was initialized correctly) and false otherwise. If uuid hasn\u0027t been initialized, the report is skipped.",
      "parentUuid": "bfc34d7b_76bd4c3f",
      "range": {
        "startLine": 1055,
        "startChar": 0,
