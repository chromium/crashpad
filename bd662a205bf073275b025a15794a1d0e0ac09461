        "id": 1172779
      },
      "writtenOn": "2020-06-23T05:06:35Z",
      "side": 1,
      "message": "If a strange file appears in the reports directory, UUIDFromReportPath() will return an uninitialized uuid. It would be better to ignore files we don\u0027t recognize.",
      "range": {
        "startLine": 1055,
        "startChar": 0,
        "endLine": 1063,
        "endChar": 15
      },
      "revId": "bd662a205bf073275b025a15794a1d0e0ac09461",
