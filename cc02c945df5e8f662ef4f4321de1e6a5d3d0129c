      "writtenOn": "2020-01-30T18:06:17Z",
      "side": 1,
      "message": "This breaks EDO -- I tried.  Reverted it back to source_set.  Why is it better as a static library?  Specifically it seemed like Service/Sources/NSKeyedArchiver+EDOAdditions.m was broken.",
      "parentUuid": "c2691136_0064e352",
      "revId": "cc02c945df5e8f662ef4f4321de1e6a5d3d0129c",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
