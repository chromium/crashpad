    },
    {
      "key": {
        "uuid": "d9f7dbb2_5f2d751c",
        "filename": "compat/android/dlfcn_internal.cc",
        "patchSetId": 15
      },
      "lineNbr": 114,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-12-22T21:15:03Z",
      "side": 1,
      "message": "But is ScopedLock even necessary? The C++ library has std::lock_guard, which is exactly what this ScopedLock is. It also has more featured lock ownership managers, like unique_lock and scoped_lock, but lock_guard should be all that’s needed here.",
      "revId": "8a7b65dc9e8973119c2ed6db733f8695d195d5f9",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "e4873540_881f7a84",
        "filename": "compat/android/dlfcn_internal.cc",
