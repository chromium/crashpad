    {
      "key": {
        "uuid": "a5c39350_9ad3b8f1",
        "filename": "compat/android/dlfcn_internal.cc",
        "patchSetId": 15
      },
      "lineNbr": 128,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-12-22T21:15:03Z",
      "side": 1,
      "message": "This results in a module initializer, and we don’t want that.\n\nFortunately, it’s really easy to avoid: since this one’s only used in a single function, Dlsym, you can just move it in-line into that function as a function-local “static”. Now it’ll be initialized (thread-safely!) at first use, but we won’t waste time or energy on it at load time (or, on non-K, ever).",
      "revId": "8a7b65dc9e8973119c2ed6db733f8695d195d5f9",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
