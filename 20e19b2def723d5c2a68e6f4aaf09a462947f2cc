    {
      "key": {
        "uuid": "69b86e95_a2482961",
        "filename": "util/posix/process_info_linux.cc",
        "patchSetId": 2
      },
      "lineNbr": 61,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-02-27T16:37:05Z",
      "side": 1,
      "message": "sscanf() returns a result code that you should use. That’s a much better check thean the 0-checks below on line 79.\n\nTechnically you can even do all of this with the sscanf() calls without even calling strncmp().",
      "revId": "20e19b2def723d5c2a68e6f4aaf09a462947f2cc",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
    },
    {
      "key": {
        "uuid": "6bf78dfa_8c8f6595",
        "filename": "util/posix/process_info_linux.cc",
