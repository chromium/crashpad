      "lineNbr": 63,
      "author": {
        "id": 1174099
      },
      "writtenOn": "2017-02-27T16:37:05Z",
      "side": 1,
      "message": "But I’m not convinced that you should stick with the stdio-family sscanf() for reasons already discussed. On top of that, it doesn’t give a good signal of overflow detection.",
      "revId": "20e19b2def723d5c2a68e6f4aaf09a462947f2cc",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": true
