    {
      "key": {
        "uuid": "101e16c7_c5a05506",
        "filename": "util/posix/process_info_test.cc",
        "patchSetId": 2
      },
      "lineNbr": 159,
      "author": {
        "id": 1144624
      },
      "writtenOn": "2017-03-01T16:28:16Z",
      "side": 1,
      "message": "The restrictions will also be SELinux-based. The \"shell\" domain is part of the \"app\" domain, which can ptrace other things in the app domain, but not things outside of it. Init (pid 1) is in the \"init\" domain, so that\u0027s why this won\u0027t work. But most other reliable system services will be in a different domain, too.",
      "parentUuid": "969e67a5_e06a3455",
      "revId": "20e19b2def723d5c2a68e6f4aaf09a462947f2cc",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
      "unresolved": false
    },
