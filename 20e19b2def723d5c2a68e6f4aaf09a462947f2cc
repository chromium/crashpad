        "id": 1144624
      },
      "writtenOn": "2017-03-01T16:28:16Z",
      "side": 1,
      "message": "Alternatively, this could just use StringPrintf.",
      "parentUuid": "1cd76970_376b0ea4",
      "revId": "20e19b2def723d5c2a68e6f4aaf09a462947f2cc",
