        "id": 1174099
      },
      "writtenOn": "2017-04-24T14:44:20Z",
      "side": 1,
      "message": "Is this a question for you or for me? It needs to be addressed.",
      "revId": "bf45ada33a432caf27bc795e6b55a10ca7cd9b70",
      "serverId": "3ce6091f-6c88-37e8-8c75-72f92ae8dfba",
